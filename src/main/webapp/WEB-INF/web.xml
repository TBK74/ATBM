<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error/500.jsp</location>
    </error-page>

    <servlet>
        <servlet-name>SepayPaymentServlet</servlet-name>
        <servlet-class>vn.edu.hcmuaf.fit.controller.payment.SepayPaymentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SepayPaymentServlet</servlet-name>
        <url-pattern>/payment/sepay</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SepayQrServlet</servlet-name>
        <servlet-class>vn.edu.hcmuaf.fit.controller.payment.SepayQrServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SepayQrServlet</servlet-name>
        <url-pattern>/payment/sepay/qr</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SepayWebhookServlet</servlet-name>
        <servlet-class>vn.edu.hcmuaf.fit.controller.payment.SepayWebhookServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SepayWebhookServlet</servlet-name>
        <url-pattern>/payment/sepay/webhook</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SepayStatusServlet</servlet-name>
        <servlet-class>vn.edu.hcmuaf.fit.controller.payment.SepayStatusServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SepayStatusServlet</servlet-name>
        <url-pattern>/payment/sepay/status</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SepaySuccessServlet</servlet-name>
        <servlet-class>vn.edu.hcmuaf.fit.controller.payment.SepaySuccessServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SepaySuccessServlet</servlet-name>
        <url-pattern>/payment/sepay/success</url-pattern>
    </servlet-mapping>

</web-app>